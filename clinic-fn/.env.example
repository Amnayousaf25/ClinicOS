# Local dev: leave VITE_API_URL empty — Vite proxy (VITE_API_PROXY_TARGET) handles it.
# Production (Vercel): set VITE_API_URL to your Render backend URL:
VITE_API_URL=https://clinicos-2.onrender.com
VITE_API_PROXY_TARGET=http://localhost:4002
# Org slug used by public booking page: /booking/:orgSlug/services
VITE_ORG_SLUG=demo-clinic

# --- Vercel Deployment Settings ---
# Root Directory: clinic-fn
# Deployed Branch: main
# Build Command: npm run build
# Output Directory: dist
