{
  "name": "clinic-os-be",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=dev nest start --watch --path tsconfig.dev.json",
    "start:dev:clean": "node scripts/dev-server.js",
    "start:debug": "cross-env NODE_ENV=dev nest start --debug --watch --path tsconfig.dev.json",
    "start:prod": "cross-env NODE_ENV=prod node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "backfill:permissions": "ts-node src/seeds/backfill-permissions.ts",
    "backfill:departments": "ts-node src/seeds/backfill-departments.ts",
    "import:external-users": "ts-node src/seeds/import-external-users.ts",
    "seed:superadmin": "ts-node src/seeds/seed-superadmin-and-backfill-org.ts",
    "fix:department-refs": "ts-node src/seeds/fix-department-refs.ts",
    "backfill:org-owners": "ts-node src/seeds/backfill-org-owners.ts",
    "start:staging": "cross-env NODE_ENV=staging nest start --watch --path tsconfig.dev.json",
    "link:commit": "commitlint -E HUSKY_GIT_PARAMS",
    "lint-staged": "lint-staged --concurrent false",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "latest",
    "@aws-sdk/client-ses": "latest",
    "@aws-sdk/lib-storage": "latest",
    "@aws-sdk/s3-request-presigner": "latest",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "latest",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "latest",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "latest",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/websockets": "latest",
    "@onesignal/node-onesignal": "latest",
    "@sendgrid/mail": "latest",
    "bcrypt": "latest",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.20",
    "google-auth-library": "latest",
    "handlebars": "latest",
    "jsonwebtoken": "latest",
    "jwks-rsa": "latest",
    "mongoose": "^8.9.2",
    "openai": "^6.33.0",
    "otpauth": "latest",
    "otplib": "latest",
    "passport": "latest",
    "passport-jwt": "latest",
    "passport-local": "latest",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.0",
    "rxjs": "^7.8.1",
    "socket.io": "latest",
    "string-width": "4.2.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.6.3",
    "@commitlint/config-conventional": "^17.6.3",
    "@commitlint/lint": "^17.6.3",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "latest",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.7",
    "@types/node": "^22.19.17",
    "@types/passport-jwt": "latest",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^13.2.2",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "resolutions": {
    "string-width": "4.2.3",
    "wrap-ansi": "7.0.0",
    "**/cli-table3/string-width": "4.2.3"
  },
  "lint-staged": {
    "{src,test}/**/*.ts": [
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog",
      "prepare-commit-msg": "exec < /dev/tty && git cz --hook || true"
    }
  }
}